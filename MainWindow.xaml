<Window
    x:Class="MultiPingEnumerator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:MultiPingEnumerator"
    Title="MultiPing Enumerator"
    Height="710" 
    Width="400"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <local:PacketConverter x:Key="PacketConverter"/>
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,10"/> <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="4"/>
                </Style>
            </Style.Resources>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#0078D7"/>
                    <Setter Property="BorderThickness" Value="1.5"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFA"/>
                    <Setter Property="BorderBrush" Value="#AAAAAA"/>
                </Trigger>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                    <Setter Property="BorderBrush" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="RoundedToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#E1E1E1"/> <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" 
                                              Focusable="False" 
                                              HorizontalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}" 
                                              RecognizesAccessKey="True" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="border" Property="Background" Value="CadetBlue"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="SteelBlue"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" 
                                              Focusable="False" 
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" 
                                    Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Tag}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#CCCCCC"/>
                                <Setter Property="Foreground" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernSliderThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Width" Value="20" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="grip" 
                                 Fill="White" 
                                 Stroke="#0078D7" 
                                 StrokeThickness="2" 
                                 VerticalAlignment="Center" 
                                 HorizontalAlignment="Center">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.2"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="grip" Property="StrokeThickness" Value="3"/>
                                <Setter TargetName="grip" Property="Fill" Value="#F0F8FF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="true">
                                <Setter TargetName="grip" Property="Fill" Value="#0078D7"/>
                                <Setter TargetName="grip" Property="Stroke" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20" HorizontalAlignment="Center" Width="300">

                <TextBlock Text="Connection Status"
                           HorizontalAlignment="Center"
                           FontSize="16"
                           FontWeight="Bold"/>

                <Grid Width="150" Height="150" Margin="20,10">
                    <Ellipse Stroke="LightGray" StrokeThickness="12" Margin="6"/>
                
                    <Path x:Name="ProgressPath" Stroke="{Binding UpdateUI.ArcColor}" StrokeThickness="12" 
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="{Binding UpdateUI.IsArcVisible}">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="75,6">
                                    <ArcSegment Size="69,69" SweepDirection="Clockwise" IsLargeArc="{Binding UpdateUI.IsLargeArc}" Point="{Binding UpdateUI.ArcEndPoint}"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <TextBlock x:Name="ProgressPercentage"
                               Text="{Binding UpdateUI.HealthDisplay}" 
                               VerticalAlignment="Center" 
                               HorizontalAlignment="Center" 
                               FontSize="24" 
                               FontWeight="ExtraBold"/>
                </Grid>

                <Border Background="#F3F3F3" CornerRadius="20" Padding="15,8" HorizontalAlignment="Center" Margin="0,15">
                    <Grid x:Name="StatBar">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" x:Name="ReceivedPackets" HorizontalAlignment="Center">
                            <Run Text="Received " FontSize="11" Foreground="#666"/>
                            <Run Text="{Binding UpdateUI.Success}" FontWeight="SemiBold" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="|" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" x:Name="LostPackets" HorizontalAlignment="Center">
                            <Run Text="Lost " FontSize="11" Foreground="#666"/>
                            <Run Text="{Binding UpdateUI.Failure}" FontWeight="SemiBold" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Grid.Column="3" Text="|" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" x:Name="Latency" HorizontalAlignment="Center">
                            <Run Text="Latency " FontSize="11" Foreground="#666"/>
                            <Run Text="{Binding UpdateUI.AverageLatency}" FontWeight="SemiBold" FontSize="14"/>
                            <Run Text="ms" FontSize="10" Foreground="#999"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="IP Address" Margin="0,0,0,5" FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                    <TextBox x:Name="IPAddress" 
                             ToolTip="e.g., 1.1.1.1"
                             Style="{StaticResource ModernTextBox}"
                             KeyDown="Input_KeyDown"
                             TextChanged="IPAddress_TextChanged"
                             Margin="0,0,0,15"
                             Text="{Binding UserSettings.IPAddress, UpdateSourceTrigger=PropertyChanged}"/>

                    <Expander Header="Collector Enumerator" HorizontalAlignment="Stretch" Margin="0,0,0,10" Visibility="{Binding UserSettings.ExpanderVisibility}"
                              FontSize="14" FontWeight="SemiBold" Foreground="#333">
                        <Expander.Resources>
                            <Style TargetType="Expander">
                                <Setter Property="Background" Value="#F3F3F3"/>
                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="10"/>
                            </Style>
                        </Expander.Resources>

                        <Border BorderBrush="#DDD" BorderThickness="1,0,1,1" CornerRadius="0,0,4,4" Background="#F9F9F9">
                            <StackPanel Margin="15">
                                <Button x:Name="EnumButton" Content="Scan Concentrator" Background="CadetBlue" BorderThickness="1" Click="EnumButton_Click" Style="{StaticResource RoundedButtonStyle}" Tag="Silver"/>

                                <ProgressBar x:Name="EnumProgress" 
                                     Height="4" 
                                     Margin="0,10" 
                                     IsIndeterminate="True" 
                                     Background="Transparent" 
                                     BorderThickness="0"
                                     Foreground="CadetBlue"
                                     Visibility="{Binding UpdateUI.ScanningVisibility}"/>

                                <Separator Margin="0,10" Background="#EEE"/>
        
                                <WrapPanel Orientation="Horizontal" Margin="0,10,0,0" ItemWidth="130" Visibility="{Binding UpdateUI.IsIsnGridVisible}">
                                    <TextBlock x:Name="ISN1" Text="{Binding UpdateUI.ISN1}" Margin="5"/>
                                    <TextBlock x:Name="ISN2" Text="{Binding UpdateUI.ISN2}" Margin="5"/>
                                    <TextBlock x:Name="ISN3" Text="{Binding UpdateUI.ISN3}" Margin="5"/>
                                    <TextBlock x:Name="ISN4" Text="{Binding UpdateUI.ISN4}" Margin="5"/>
                                </WrapPanel>
                                 <TextBlock x:Name="EnumMessage" Visibility="{Binding UpdateUI.IsEnumMessageVisible}" HorizontalAlignment="Center" 
                                            Text="{Binding UpdateUI.EnumMessage}" Margin="5" FontStyle="Italic" Foreground="DimGray"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <TextBlock Text="Port" Margin="0,0,0,5" FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                    <TextBox x:Name="Port" 
                             ToolTip="Optional (Standard Ping)"
                             KeyDown="Input_KeyDown"
                             Style="{StaticResource ModernTextBox}"
                             InputScope="Number"
                             MaxLength="5"
                             Margin="0,0,0,15"
                             IsEnabled="{Binding UserSettings.IsPortEnabled}"
                             PreviewTextInput="Port_PreviewTextInput"
                             DataObject.Pasting="Port_Pasting"
                             Text="{Binding UserSettings.Port, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Number of Packets" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Value, ElementName=PacketSlider, Converter={StaticResource PacketConverter}}" HorizontalAlignment="Right" Foreground="Gray" Margin="10,0,0,0"/>
                        </DockPanel>
                        
                        <Slider x:Name="PacketSlider" Minimum="1" Maximum="21" Value="{Binding UserSettings.PacketCount}"
                                IsSnapToTickEnabled="True" TickFrequency="1" Margin="0,0,0,15" VerticalAlignment="Center">
                            <Slider.Resources>
                                <Style TargetType="Thumb" BasedOn="{StaticResource ModernSliderThumb}"/>
                                <Style TargetType="RepeatButton" x:Key="TrackButtonStyle">
                                    <Setter Property="OverridesDefaultStyle" Value="true"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Rectangle Fill="#DDDDDD" Height="4" RadiusX="2" RadiusY="2"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Slider.Resources>
                        </Slider>

                    </StackPanel> 

                    <ToggleButton x:Name="ProtocolToggle" IsChecked="{Binding UserSettings.IsUdpMode, Mode=TwoWay}" Height="35" Width="250" FontSize="14" FontWeight="SemiBold">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton" BasedOn="{StaticResource RoundedToggleStyle}">
                                <Setter Property="Content" Value="Standard (ICMP/TCP)"/>
                                <Style.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Content" Value="Concentrator (UDP)"/>
                                </Trigger>
                            </Style.Triggers>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>

                    <Separator Margin="0,15" Background="#EEE"/>

                    <Button x:Name="StartButton" Content="Start Ping" Click="StartButton_Click" Style="{StaticResource RoundedButtonStyle}" Height="35" 
                            Width="250" Margin="0,5" FontSize="14" FontWeight="SemiBold" Tag="Silver"/>

                    <Button x:Name="EndButton" Content="End Ping" Visibility="Collapsed" Click="EndButton_Click" Style="{StaticResource RoundedButtonStyle}" 
                            Height="35" Width="250" Margin="0,5" FontSize="14" FontWeight="SemiBold" Tag="Silver"/>

                    <TextBlock x:Name="PingMessage" Visibility="{Binding UpdateUI.IsPingMessageVisible}" HorizontalAlignment="Center" Text="{Binding UpdateUI.PingMessage}" 
                               FontStyle="Italic" Foreground="DimGray" FontSize="14" FontWeight="SemiBold" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>