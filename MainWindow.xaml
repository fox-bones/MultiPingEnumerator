<Window x:Class="MultiPingEnumerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MultiPingEnumerator"
        Title="Midmark Concentrator Ping Enumerator"
        Height="550" Width="425"
        Background="#1C1C1E"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:PacketConverter x:Key="PacketConverter"/>

        <!-- ── Colours ── -->
        <SolidColorBrush x:Key="SurfaceBrush"     Color="#1C1C1E" />
        <SolidColorBrush x:Key="PanelBrush"       Color="#2A2A2D" />
        <SolidColorBrush x:Key="BorderBrush"      Color="#3A3A3E" />
        <SolidColorBrush x:Key="AccentBrush"      Color="#0A84FF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F0F0F0" />
        <SolidColorBrush x:Key="TextMutedBrush"   Color="#6E6E73" />
        <SolidColorBrush x:Key="SuccessBrush"     Color="#30D158" />
        <SolidColorBrush x:Key="WarningBrush"     Color="#FFD60A" />
        <SolidColorBrush x:Key="DangerBrush"      Color="#FF453A" />

        <!-- ── Input TextBox ── -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"               Value="#222224" />
            <Setter Property="Foreground"               Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="CaretBrush"               Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush"              Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="Height"                   Value="32" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding"                  Value="8,0" />
            <Setter Property="FontFamily"               Value="Consolas" />
            <Setter Property="FontSize"                 Value="12" />
            <Setter Property="SelectionBrush"           Value="{StaticResource AccentBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary button ── -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontFamily"      Value="Consolas" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A91FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0070D8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3E" />
                                <Setter Property="Foreground" Value="#6E6E73" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Danger button (End Ping) ── -->
        <Style x:Key="DangerButtonStyle" TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FF453A" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF6259" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#CC3530" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Secondary button (Scan Concentrator) ── -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily"      Value="Consolas" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="10,5" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F2F32" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A1A1C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle (Ping Method) ── -->
        <Style x:Key="DarkToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background"      Value="#2A2A2D" />
            <Setter Property="Foreground"      Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily"      Value="Consolas" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A84FF" />
                                <Setter Property="Foreground"                  Value="White" />
                                <Setter Property="BorderBrush"                 Value="#0A84FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2F2F32" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toggle Switch (CheckBox) ── -->
        <Style x:Key="DarkToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Grid Width="36" Height="18" Margin="0,0,8,0">
                                <Border x:Name="Pill" Background="#3A3A3E" CornerRadius="9" />
                                <Ellipse x:Name="Thumb" Fill="#6E6E73" Width="12" Height="12"
                                         HorizontalAlignment="Left" Margin="3,0">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0" />
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Grid>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill"  Property="Background" Value="#0A84FF" />
                                <Setter TargetName="Thumb" Property="Fill"       Value="White" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="18" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Thumb"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                             To="0" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Slider thumb ── -->
        <Style x:Key="DarkSliderThumb" TargetType="Thumb">
            <Setter Property="SnapsToDevicePixels"  Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Width"  Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse x:Name="grip" Fill="#0A84FF" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="grip" Property="Fill" Value="#1A91FF" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="grip" Property="Fill" Value="#0070D8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource SurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Header -->
            <RowDefinition Height="Auto" />  <!-- Health ring -->
            <RowDefinition Height="Auto" />  <!-- Stat bar -->
            <RowDefinition Height="Auto" />  <!-- IP input row -->
            <RowDefinition Height="Auto" />  <!-- Settings panel -->
            <RowDefinition Height="Auto" />  <!-- Enumerator expander -->
            <RowDefinition Height="Auto" />  <!-- Action buttons -->
            <RowDefinition Height="*"    />  <!-- Spacer -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                Background="#222224"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="CONCENTRATOR"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                <TextBlock Text="PING ENUMERATOR"
                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="5,0,0,0" VerticalAlignment="Center" />
                <TextBlock Text="// Midmark"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Health gauge (half-circle / speedometer) ── -->
        <!-- ── Health gauge ── -->
        <Border Grid.Row="1" Padding="16,14,16,4" Background="{StaticResource SurfaceBrush}">
            <Grid Height="120">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left column: LOST + latency label stack -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UpdateUI.Failure}"
                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource DangerBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="LOST"
                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,1,0,0"/>
                </StackPanel>

                <!-- Centre: gauge canvas -->
                <Grid Grid.Column="1" Width="200" Height="120" HorizontalAlignment="Center">

                    <!-- Ghost track (full semicircle, dim) -->
                    <Path Stroke="#2A2A2D" StrokeThickness="10"
                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="14,100">
                                    <ArcSegment Size="86,86" SweepDirection="Clockwise"
                                                IsLargeArc="True" Point="186,100"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- Subtle inner accent ring (same arc, thinner, offset inward) -->
                    <Path Stroke="#323236" StrokeThickness="4"
                          StrokeStartLineCap="Flat" StrokeEndLineCap="Flat">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="22,100">
                                    <ArcSegment Size="78,78" SweepDirection="Clockwise"
                                                IsLargeArc="True" Point="178,100"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- Tick marks at 0%, 25%, 50%, 75%, 100% on the track -->
                    <!-- 0% = left end (14,100), 25% = 45° up-left, 50% = top, 75% = 45° up-right, 100% = right end -->
                    <!-- Computed for center=(100,100), r=86: angles 180°,135°,90°,45°,0° -->
                    <!-- Outer tick point, inner tick point (8px tick length inward from r=86) -->
                    <Line X1="14"  Y1="100" X2="22"  Y2="100" Stroke="#4A4A50" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/> <!-- 0% -->
                    <Line X1="39"  Y1="39"  X2="45"  Y2="45"  Stroke="#4A4A50" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/> <!-- 25% -->
                    <Line X1="100" Y1="14"  X2="100" Y2="22"  Stroke="#4A4A50" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/> <!-- 50% -->
                    <Line X1="161" Y1="39"  X2="155" Y2="45"  Stroke="#4A4A50" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/> <!-- 75% -->
                    <Line X1="186" Y1="100" X2="178" Y2="100" Stroke="#4A4A50" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/> <!-- 100% -->

                    <!-- Tick labels -->
                    <TextBlock Text="0" FontFamily="Consolas" FontSize="9"
                               Foreground="#4A4A50"
                               Canvas.Left="4" Canvas.Top="104"
                               VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="-2,0,0,18"/>
                    <TextBlock Text="50" FontFamily="Consolas" FontSize="9"
                               Foreground="#4A4A50"
                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-4,0,0"/>
                    <TextBlock Text="100" FontFamily="Consolas" FontSize="9"
                               Foreground="#4A4A50"
                               VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,-10, 18"/>

                    <!-- Main progress arc -->
                    <Path x:Name="ProgressPath"
                          Stroke="{Binding UpdateUI.ArcColor}"
                          StrokeThickness="10"
                          StrokeStartLineCap="Flat"
                          StrokeEndLineCap="Flat"
                          Visibility="{Binding UpdateUI.IsArcVisible}">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="14,100">
                                    <ArcSegment Size="86,86"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="{Binding UpdateUI.IsLargeArc}"
                                                Point="{Binding UpdateUI.ArcEndPoint}"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- Inner accent arc (same path, thinner, semi-transparent — gives depth) -->
                    <Path Stroke="{Binding UpdateUI.ArcColor}"
                          StrokeThickness="3"
                          Opacity="0.35"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Visibility="{Binding UpdateUI.IsArcVisible}">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="22,100">
                                    <ArcSegment Size="78,78"
                                                SweepDirection="Clockwise"
                                                IsLargeArc="{Binding UpdateUI.IsLargeArc}"
                                                Point="{Binding UpdateUI.ArcInnerEndPoint}"/>
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                    </Path>

                    <!-- Endpoint cap dot (bright dot at the arc tip) -->
                    <Ellipse Width="10" Height="10"
                             Fill="DarkGray"
                             Visibility="{Binding UpdateUI.IsArcVisible}"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top" 
                             Margin="-5,-5,0,0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform
                                X="{Binding UpdateUI.ArcCapX}"
                                Y="{Binding UpdateUI.ArcCapY}"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <!-- Centre readout -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="0,10,0,0">
                        <TextBlock Text="{Binding UpdateUI.HealthDisplay}"
                                   FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="HEALTH"
                                   FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Center" Margin="0,1,0,0"/>
                        <!-- Latency inline below health -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock Text="{Binding UpdateUI.AverageLatency}"
                                       FontFamily="Consolas" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text=" ms"
                                       FontFamily="Consolas" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>

                </Grid>

                <!-- Right column: RECEIVED -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UpdateUI.Success}"
                               FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="RCVD"
                               FontFamily="Consolas" FontSize="8" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,1,0,0"/>
                </StackPanel>

            </Grid>
        </Border>

        <!-- ── Stat bar ── -->
        <Border Grid.Row="2"
                Background="#222224"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Margin="16,0,16,12"
                Padding="12,8"
                Visibility="Collapsed">

            <!-- Latency -->
            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                <TextBlock Text="LATENCY" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                            Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding UpdateUI.AverageLatency}" FontFamily="Consolas"
                                FontSize="16" FontWeight="Bold"
                                Foreground="{StaticResource WarningBrush}" />
                    <TextBlock Text="ms" FontFamily="Consolas" FontSize="10"
                                Foreground="{StaticResource TextMutedBrush}"
                                Margin="3,0,0,0" VerticalAlignment="Bottom" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── IP input row ── -->
        <Border Grid.Row="3" Padding="16,0,16,8" Background="{StaticResource SurfaceBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="IP"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" Margin="0,0,10,0" />

                <TextBox Grid.Column="1"
                         x:Name="IPAddress"
                         Style="{StaticResource DarkTextBox}"
                         ToolTip="e.g., 1.1.1.1"
                         KeyDown="Input_KeyDown"
                         GotFocus="IPAddress_GotFocus"
                         TextChanged="IPAddress_TextChanged"
                         Text="{Binding UserSettings.IPAddress, UpdateSourceTrigger=PropertyChanged}" />

                <Button Grid.Column="2"
                        x:Name="AddButton"
                        Content="ADD"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="32" Width="50"
                        Margin="6,0,0,0"
                        Visibility="Collapsed"
                        Click="AddIP_Click" />
            </Grid>
        </Border>

        <!-- ── Tab strip ── -->
        <Border Grid.Row="4"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Margin="16,0,16,0">
            <StackPanel Orientation="Horizontal">

                <!-- ICMP Tab -->
                <Border x:Name="IcmpTab"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="0,0,0,2"
                        Padding="16,8"
                        Cursor="Hand"
                        MouseLeftButtonDown="IcmpTab_Click">
                    <TextBlock x:Name="IcmpTabText"
                               Text="ICMP"
                               FontFamily="Consolas"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" />
                </Border>

                <!-- TCP Tab -->
                <Border x:Name="TcpTab"
                        BorderBrush="Transparent"
                        BorderThickness="0,0,0,2"
                        Padding="16,8"
                        Cursor="Hand"
                        MouseLeftButtonDown="TcpTab_Click">
                    <TextBlock x:Name="TcpTabText"
                               Text="TCP"
                               FontFamily="Consolas"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" />
                </Border>

                <!-- UDP Tab -->
                <Border x:Name="UdpTab"
                        BorderBrush="Transparent"
                        BorderThickness="0,0,0,2"
                        Padding="16,8"
                        Cursor="Hand"
                        MouseLeftButtonDown="UdpTab_Click">
                    <TextBlock x:Name="UdpTabText"
                               Text="UDP/CONCENTRATOR"
                               FontFamily="Consolas"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" />
                </Border>

                <!-- ENUMERATOR Tab -->
                <Border x:Name="EnumTab"
                        BorderBrush="Transparent"
                        BorderThickness="0,0,0,2"
                        Padding="16,8"
                        Cursor="Hand"
                        MouseLeftButtonDown="EnumTab_Click">
                    <TextBlock x:Name="EnumTabText"
                               Text="COLLECTOR ENUMERATOR"
                               FontFamily="Consolas"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" />
                </Border>

            </StackPanel>
        </Border>

        <!-- ── Tab content panels ── -->

        <!-- ICMP panel -->
        <Border x:Name="IcmpPanel"
                Grid.Row="5"
                Background="#222224"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Margin="16,8,16,8"
                Padding="12,10"
                Visibility="Visible">
            <StackPanel>
                <TextBlock Text="ICMP CONFIGURATION" FontFamily="Consolas" FontSize="9"
                           FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10" />
                <TextBlock Text="PACKETS" FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5" />
                <DockPanel Margin="0,0,0,5">
                    <TextBlock Text="{Binding Value, ElementName=IcmpPacketSlider,
                                       Converter={StaticResource PacketConverter}}"
                               HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="{StaticResource AccentBrush}" />
                </DockPanel>
                <Slider x:Name="IcmpPacketSlider"
                        Minimum="1" Maximum="21"
                        Value="{Binding UserSettings.PacketCount}"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        ToolTip="Slide right for a continuous ping"
                        Margin="0,0,0,10">
                    <Slider.Resources>
                        <Style TargetType="Thumb" BasedOn="{StaticResource DarkSliderThumb}" />
                    </Slider.Resources>
                </Slider>
            </StackPanel>
        </Border>

        <!-- TCP panel -->
        <Border x:Name="TcpPanel"
                Grid.Row="5"
                Background="#222224"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Margin="16,8,16,8"
                Padding="12,10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="TCP CONFIGURATION" FontFamily="Consolas" FontSize="9"
                           FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10" />
                <TextBlock Text="PORT" FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5" />
                <TextBox x:Name="TcpPort"
                         Style="{StaticResource DarkTextBox}"
                         ToolTip="Target port (e.g. 443)"
                         MaxLength="5"
                         PreviewTextInput="Port_PreviewTextInput"
                         DataObject.Pasting="Port_Pasting"
                         GotFocus="Port_GotFocus"
                         Margin="0,0,0,10"
                         Text="{Binding UserSettings.Port, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="PACKETS" FontFamily="Consolas" FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5" />
                <DockPanel Margin="0,0,0,5">
                    <TextBlock Text="{Binding Value, ElementName=IcmpPacketSlider,
                                       Converter={StaticResource PacketConverter}}"
                               HorizontalAlignment="Right"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="{StaticResource AccentBrush}" />
                </DockPanel>
                <Slider x:Name="TcpPacketSlider"
                        Minimum="1" Maximum="21"
                        Value="{Binding UserSettings.PacketCount}"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        ToolTip="Slide right for a continuous ping"
                        Margin="0,0,0,10">
                    <Slider.Resources>
                        <Style TargetType="Thumb" BasedOn="{StaticResource DarkSliderThumb}" />
                    </Slider.Resources>
                </Slider>
            </StackPanel>
        </Border>

        <!-- UDP panel -->
        <Border x:Name="UdpPanel"
                Grid.Row="5"
                Background="#222224"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Margin="16,8,16,8"
                Padding="12,10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="UDP CONFIGURATION" FontFamily="Consolas" FontSize="9"
                           FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10" />
                <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                    <TextBlock Text="IP QUEUE" FontFamily="Consolas" FontSize="10"
                        Foreground="{StaticResource TextMutedBrush}" Grid.Column="0" VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1"
                              x:Name="ExportCheckBox"
                              Content="Export results"
                              Style="{StaticResource DarkToggleSwitch}"
                              IsChecked="{Binding UserSettings.IsExportEnabled}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Right"
                              RenderTransformOrigin="1,0.5">
                        <CheckBox.RenderTransform>
                            <ScaleTransform ScaleX="0.8" ScaleY="0.8" />
                        </CheckBox.RenderTransform>
                    </CheckBox>
                </Grid>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Background="#1C1C1E">
                        <ScrollViewer Height="80" VerticalScrollBarVisibility="Auto">
                            <ListBox ItemsSource="{Binding UserSettings.IPHistory}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     MouseDoubleClick="IPHistoryListBox_MouseDoubleClick">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background"       Value="Transparent" />
                                        <Setter Property="BorderThickness"  Value="0" />
                                        <Setter Property="Padding"          Value="2" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#2F2F32" />
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2A2A2D" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4,2"
                                                    Background="Transparent"
                                                    ToolTip="Double-click to remove">
                                            <TextBlock Width="16" FontFamily="Consolas" FontSize="11"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="●" />
                                                        <Setter Property="Foreground" Value="#6E6E73" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                <Setter Property="Text"       Value="✓" />
                                                                <Setter Property="Foreground" Value="#30D158" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                                <Setter Property="Text"       Value="✕" />
                                                                <Setter Property="Foreground" Value="#FF453A" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding IP}"
                                                       FontFamily="Consolas" FontSize="11"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                <!-- Queue empty hint -->
                <TextBlock Text="No IPs queued — add one above"
                           FontFamily="Consolas" FontSize="10" FontStyle="Italic"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UserSettings.IPHistory.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
            </StackPanel>
        </Border>

        <!-- ENUMERATOR panel -->
        <Border x:Name="EnumPanel"
                Grid.Row="5"
                Background="#222224"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Margin="16,8,16,8"
                Padding="12,10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="COLLECTOR ENUMERATION" FontFamily="Consolas" FontSize="9"
                           FontWeight="Bold" Foreground="{StaticResource AccentBrush}"
                           Margin="0,0,0,10" />
                <ProgressBar x:Name="EnumProgress"
                             Height="2" Margin="0,12,0,8"
                             IsIndeterminate="True"
                             Background="#2A2A2D"
                             Foreground="{StaticResource AccentBrush}"
                             Visibility="{Binding UpdateUI.ScanningVisibility}" />
                <UniformGrid Columns="2" Margin="0,5">
                    <Border Background="#1C1C1E" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Margin="0,0,4,4" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ISN 1  " FontFamily="Consolas" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UpdateUI.ISN1}" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="#1C1C1E" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Margin="4,0,0,4" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ISN 2  " FontFamily="Consolas" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UpdateUI.ISN2}" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="#1C1C1E" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Margin="0,0,4,0" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ISN 3  " FontFamily="Consolas" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UpdateUI.ISN3}" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="#1C1C1E" BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" Margin="4,0,0,0" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ISN 4  " FontFamily="Consolas" FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding UpdateUI.ISN4}" FontFamily="Consolas"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>
        
        <!-- ── Action buttons ── -->
        <Border Grid.Row="6" Padding="16,0,16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton"
                        Grid.Column="0"
                        Content="START PING"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Height="34"
                        Margin="0,0,6,0"
                        Click="StartButton_Click" />

                <Button x:Name="EndButton"
                        Grid.Column="1"
                        Content="END PING"
                        Style="{StaticResource DangerButtonStyle}"
                        Height="34" Width="110"
                        Visibility="Collapsed"
                        Click="EndButton_Click" />
            </Grid>
        </Border>

        <!-- ── Status bar ── -->
        <Border Grid.Row="8"
                Background="#222224"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="StatusDotIcmp"
                         Width="7" Height="7"
                         Fill="{StaticResource TextMutedBrush}"
                         VerticalAlignment="Center" Margin="0,0,7,0" />
                <TextBlock x:Name="StatusTextIcmp"
                           Text="Ready"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" />

                <Ellipse x:Name="StatusDotTcp"
                         Width="7" Height="7"
                         Fill="{StaticResource TextMutedBrush}"
                         VerticalAlignment="Center" Margin="0,0,7,0"
                         Visibility="Collapsed"/>
                <TextBlock x:Name="StatusTextTcp"
                           Text="Ready"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <Ellipse x:Name="StatusDotUdp"
                         Width="7" Height="7"
                         Fill="{StaticResource TextMutedBrush}"
                         VerticalAlignment="Center" Margin="0,0,7,0"
                         Visibility="Collapsed"/>
                <TextBlock x:Name="StatusTextUdp"
                           Text="Ready"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

                <Ellipse x:Name="StatusDotEnum"
                         Width="7" Height="7"
                         Fill="{StaticResource TextMutedBrush}"
                         VerticalAlignment="Center" Margin="0,0,7,0"
                         Visibility="Collapsed"/>
                <TextBlock x:Name="StatusTextEnum"
                           Text="Ready"
                           FontFamily="Consolas" FontSize="11"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>